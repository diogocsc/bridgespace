SECRET_KEY=replace-with-long-random-string
DATABASE_URL=sqlite:///bridgespace.db
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_API_KEY="YOUR_KEY"
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@bridgespace.app
# reCAPTCHA v2 (optional): public forms use it when both keys are set. Get keys at https://www.google.com/recaptcha/admin
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from Dashboard → Developers → Webhooks (starts with whsec_)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Superadmin seed (used when no superadmin exists yet)
SUPERADMIN_EMAIL=admin@bridgespace.local
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=your-secure-password